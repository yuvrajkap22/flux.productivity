rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidUsername(username) {
      return username.matches('[a-z0-9_]{3,20}');
    }

    // Users collection - profile and pet data
    match /users/{uid} {
      allow read: if isAuthenticated() && (isOwner(uid) || resource.data.isPublic == true);
      allow create: if isOwner(uid) && 
        request.resource.data.uid == uid &&
        request.resource.data.email == request.auth.email &&
        request.resource.data.keys().hasAll(['displayName', 'email', 'onboardingComplete']);
      
      allow update: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.email == resource.data.email;
      
      allow delete: if isOwner(uid);

      // Pet subcollection operations controlled by parent user doc
      match /pet/{document=**} {
        allow read, write: if isOwner(uid);
      }

      // Stats subcollection
      match /stats/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Usernames collection - ensure uniqueness
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated() && 
        isValidUsername(username) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.displayName != '';
      
      allow update: if isOwner(resource.data.uid);
      allow delete: if isOwner(resource.data.uid);
    }

    // Leaderboard rows keyed by user uid
    match /leaderboard/{uid} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isOwner(uid);
    }

    // Public profile data for leaderboard
    match /publicProfiles/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && 
        request.resource.data.displayName != '' &&
        request.resource.data.uid == uid;
    }

    // Challenges data (optional collection for future use)
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false; // Managed by app or admin
    }

    // User challenges progress
    match /userChallenges/{uid}/{challengeId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
