{
  "name": "flux-productivity",
  "version": "2.0.2",
  "private": true,
  "description": "Flux Productivity: Pomodoro timer and simple productivity tools.",
  "scripts": {
    "build": "npm run build:dist",
    "build:dist": "node scripts/build-dist.mjs",
    "ci": "npm run build",
    "release": "bash scripts/release.sh",
    "serve": "npx serve dist -l 8080",
    "test:headless": "node scripts/headless-check.mjs http://127.0.0.1:8080/login.html",
    "test:headless:ci": "node scripts/headless-ci.mjs",
    "test:e2e": "node scripts/headless-e2e.mjs http://127.0.0.1:8081"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.39.2"
  },
  "dependencies": {
    "lighthouse": "^13.3.0",
    "puppeteer": "^25.0.3",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "serve": "^14.2.6"
  }
}
