{
  "name": "flux-productivity",
  "version": "2.0.0",
  "private": true,
  "description": "Flux static web app with deployment minification pipeline.",
  "scripts": {
    "build": "npm run build:dist",
    "build:dist": "node scripts/build-dist.mjs",
    "verify:dist": "node scripts/verify-dist.mjs",
    "verify": "npm run build && npm run verify:dist",
    "ci": "npm run verify",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.47.1"
  }
}
